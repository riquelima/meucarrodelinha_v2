  url_doc_veiculo text,
  CONSTRAINT motoristas_pkey PRIMARY KEY (usuario_id),
  CONSTRAINT motoristas_usuario_id_fkey FOREIGN KEY (usuario_id) REFERENCES public.usuarios(id)
);
CREATE TABLE public.postagens (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  titulo text NOT NULL,
  slug text UNIQUE,
  categoria text CHECK (categoria = ANY (ARRAY['noticias'::text, 'dicas'::text, 'promocoes'::text, 'avisos'::text])),
  conteudo text NOT NULL,
  imagem_capa_url text,
  autor_id uuid,
