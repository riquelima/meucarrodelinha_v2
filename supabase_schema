  imagem_url text,
  link_acao text,
  ativo boolean DEFAULT true,
  criado_por uuid,
  criado_em timestamp with time zone NOT NULL DEFAULT timezone('utc'::text, now()),
  url text,
  CONSTRAINT anuncios_pkey PRIMARY KEY (id),
  CONSTRAINT anuncios_criado_por_fkey FOREIGN KEY (criado_por) REFERENCES public.usuarios(id)
