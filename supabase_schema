CREATE TABLE public.viagens (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  passageiro_id uuid,
  motorista_id uuid,
  origem_endereco text NOT NULL,
  origem_lat numeric,
  origem_lng numeric,
  destino_endereco text NOT NULL,
  destino_lat numeric,
  destino_lng numeric,
  data_hora_agendada timestamp with time zone,
  status text DEFAULT 'pendente'::text CHECK (status = ANY (ARRAY['agendada'::text, 'aceita'::text, 'cancelada'::text, 'Finalizado'::text, 'Em Aberto'::text, 'concluida'::text])),
  valor_estimado numeric,
  valor_final numeric,
  avaliacao_motorista integer CHECK (avaliacao_motorista >= 1 AND avaliacao_motorista <= 5),
  comentario_passageiro text,
  criado_em timestamp with time zone NOT NULL DEFAULT timezone('utc'::text, now()),
  CONSTRAINT viagens_pkey PRIMARY KEY (id),
  CONSTRAINT viagens_passageiro_id_fkey FOREIGN KEY (passageiro_id) REFERENCES public.usuarios(id),
  CONSTRAINT viagens_motorista_id_fkey FOREIGN KEY (motorista_id) REFERENCES public.motoristas(usuario_id)
);