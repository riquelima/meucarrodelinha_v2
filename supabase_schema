  viagem_id uuid,
  remetente_id uuid NOT NULL,
  destinatario_id uuid NOT NULL,
  conteudo text NOT NULL,
  lida boolean DEFAULT false,
  enviada_em timestamp with time zone NOT NULL DEFAULT timezone('utc'::text, now()),
  CONSTRAINT mensagens_pkey PRIMARY KEY (id),
  CONSTRAINT mensagens_viagem_id_fkey FOREIGN KEY (viagem_id) REFERENCES public.viagens(id),
  CONSTRAINT mensagens_remetente_id_fkey FOREIGN KEY (remetente_id) REFERENCES public.usuarios(id),
  CONSTRAINT mensagens_destinatario_id_fkey FOREIGN KEY (destinatario_id) REFERENCES public.usuarios(id)
);
CREATE TABLE public.motoristas (
